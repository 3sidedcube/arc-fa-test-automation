<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Android Suite" parallel="false" thread-count="1">

    <test name="Android Tests">
        <parameter name="platform" value="android"/>

        <!-- TODO QA: Add path to app file and the build number when testing locally. Add in the "resources" directory-->
        <parameter name="build" value="src/test/resources/apps/android/staging_4067.apk"/>
        <parameter name="buildNumber" value="4067"/>

        <!-- TODO QA: To get the Android device udid, run the following in the terminal: adb devices -->
        <parameter name="deviceName" value="Pixel 7"/>
        <parameter name="udid" value="33071FDH2007QH"/>
        <parameter name="fullReset" value="true"/> <!-- Update fullReset to "true" if you want run each test from a fresh install -->

        <!-- Add correct environment for env specific tests and test data to be selected -->
        <parameter name="env" value="prod"/>
        <parameter name="isSimulator" value="false"/>
        
        <!-- App-specific parameters for performance optimization -->
        <parameter name="androidPackageName" value="com.cube.arc.fa"/>



        <!-- Set up the test types to run here -->
        <groups>
            <run> <!-- Sets which type tests will run, e.g. "onboarding", "regression" etc. -->
                <!-- <include name="smoke"/> -->
            </run>
        </groups>

        <!-- Add test classes in here -->
        <classes>
            <!-- <class name="tests.WelcomeScreenTest"/> -->
            <!-- <class name="tests.SignInScreenTest"/> -->
            <class name="tests.LocationPermissionsTest"/>
            <class name="tests.TermsOfServiceTest"/>
        </classes>
    </test>
</suite>
